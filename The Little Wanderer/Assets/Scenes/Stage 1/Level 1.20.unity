  m_Script: {fileID: 11500000, guid: cdf0a0e20a20c4f7e8a0b2281f51dcd3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  quizUI: {fileID: 588434392}
  questions:
  - questionInfo: 
    questionType: 1
    imageText: Jane has this much money. She wants to buy some snacks. A snack costs
      $0.40 each. How many snacks can she buy?
    questionImg: {fileID: 21300000, guid: d240aa3a257da4ff2a7c513ca6a4d56b, type: 3}
    options:
    - 28
    - 3
    - 26
    - 24
    correctAns: 28
  - questionInfo: A school has 6 levels. Each level has 3 classes. Each class has
      2 fans. How many fans does this school have?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 12
    - 18
    - 24
    - 36
    correctAns: 36
  - questionInfo: 'Choose the smallest number. '
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 73
    - 59
    - 90
    - 81
    correctAns: 59
  - questionInfo: Which number is greater than 75 but smaller than 92?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 75
    - 62
    - 92
    - 84
    correctAns: 84
  - questionInfo: 
    questionType: 1
    imageText: What is the product of the 2nd smallest and 3nd largest number?
    questionImg: {fileID: 21300000, guid: 2ce3dbd7d76484ea7a59f2227968f77f, type: 3}
    options:
    - 48
    - 24
    - 36
    - 64
    correctAns: 48
  - questionInfo: 
    questionType: 1
    imageText: Pearl has math lesson from 8am to 9am, english lesson from 9am to
      10am, and science lesson from 10am to 11am and then lunch from 11am to 12pm.
      What lesson does she have at the time shown below?
    questionImg: {fileID: 21300000, guid: 63e498e96c5cc44339797d421e7e2e57, type: 3}
    options:
    - Math
    - English
    - Science
    - Lunch
    correctAns: English
  - questionInfo: Rachel has 6 bracelets. Her friend Valentina has 3 more than her.
      How many bracelets do they have in total?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 9
    - 15
    - 18
    - 3
    correctAns: 15
  - questionInfo: Penny bought 29 red cups and 5 green cups. How many cups did she
      buy in total?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 24
    - 34
    - 29
    - 32
    correctAns: 34
  - questionInfo: _____ + 19 = 85
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 65
    - 66
    - 64
    - 63
    correctAns: 66
  - questionInfo: Ms Wong has 18 oranges. She packed the oranges equaly into 3 bags.
      How many oranges does each bag have?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 15
    - 21
    - 9
    - 6
    correctAns: 6
  animator: {fileID: 476059848}
