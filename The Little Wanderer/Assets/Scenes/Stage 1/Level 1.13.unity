  quizUI: {fileID: 266130264}
  questions:
  - questionInfo: How much is six sixes?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - six
    - sixteen
    - twenty-six
    - thirty-six
    correctAns: thirty-six
  - questionInfo: 
    questionType: 1
    imageText: Ismail went to the toy shop with $20. Which toy can he buy?
    questionImg: {fileID: 21300000, guid: 9a49920770ba447c7b680279c4405f78, type: 3}
    options:
    - Toy Train
    - Football
    - Toy Plane
    - Nitendo Game
    correctAns: Football
  - questionInfo: 
    questionType: 1
    imageText: How much more expensive is the nitendo game compared to the toy plane?
    questionImg: {fileID: 21300000, guid: 9a49920770ba447c7b680279c4405f78, type: 3}
    options:
    - $14
    - $30
    - $38
    - $28
    correctAns: $14
  - questionInfo: Betty baked 19 tarts. 6 are egg tarts, 8 are cheese tarts and the
      rest are apple tarts. How many egg and apple tarts are there in total?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 14
    - 5
    - 11
    - 13
    correctAns: 11
  - questionInfo: 15 children go to the zoo. 7 of them are girls. How many boys are
      there?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 7
    - 8
    - 6
    - 9
    correctAns: 8
  - questionInfo: Jane started reading her new book at 2:00. It was so interesting
      that she finished it in one hour. What time did Jane finish reading?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 2:00
    - 3:00
    - 4:00
    - 5:00
    correctAns: 3:00
  - questionInfo: 2 tens + 4 ones = _____
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 14
    - 20
    - 24
    - 42
    correctAns: 24
  - questionInfo: 
    questionType: 1
    imageText: The lion is in the _____ position.
    questionImg: {fileID: 21300000, guid: c05a93f46724947d0bf00e98db644cff, type: 3}
    options:
    - fourth
    - fifth
    - third
    - second
    correctAns: fifth
  - questionInfo: Mr Lim has 6 boxes. Each book has 3 books. How many books are there
      in total?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 18
    - 24
    - 21
    - 9
    correctAns: 18
  - questionInfo: Amira baked 18 pies. She kept 6 of them for her family and sold
      the rest for $1.20 each. How much money did she make?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - $12
    - $18
    - $14.40
    - $21.60
    correctAns: $14.40
