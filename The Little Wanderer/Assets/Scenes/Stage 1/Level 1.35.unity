  quizUI: {fileID: 625177771}
  questions:
  - questionInfo: 
    questionType: 1
    imageText: Which one is the correct multiplication equation?
    questionImg: {fileID: 21300000, guid: 6ad9fa239347842689d33820c291c899, type: 3}
    options:
    - 7 X 2 = 14
    - 7 + 2 = 9
    - 7 + 7 = 14
    - 6 X 2 = 12
    correctAns: 7 X 2 = 14
  - questionInfo: 
    questionType: 1
    imageText: Tom has the following coins. He bought 3 fishballs for 10 cents each.
      How much does he have left?
    questionImg: {fileID: 21300000, guid: 15990906d2a624409a8556f6e3010325, type: 3}
    options:
    - 75 cents
    - 65 cents
    - 45 cents
    - 90 cents
    correctAns: 45 cents
  - questionInfo: 
    questionType: 1
    imageText: 'How much does James need to pay if he wants to buy a train, a robot
      and 2 chess set? '
    questionImg: {fileID: 21300000, guid: b435a989960f2448e8abc880ff784482, type: 3}
    options:
    - $60
    - $76
    - $64
    - $87
    correctAns: $64
  - questionInfo: _____ is 5 less than 42.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 92
    - 47
    - 43
    - 37
    correctAns: 37
  - questionInfo: 93 is the same as 8 tens and _____ ones.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 13
    - 10
    - 3
    - 9
    correctAns: 13
  - questionInfo: Choose the option with the least value.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 4 tens - 15 ones
    - 17 + 13
    - 27
    - 8 less than 22
    correctAns: 8 less than 22
  - questionInfo: Bala has 62 cards. He has 18 more cards than John. How many cards
      does John have?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 80 cards
    - 44 cards
    - 54 cards
    - 56 cards
    correctAns: 44 cards
  - questionInfo: A 5 dollar note has the same value as which option?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 5 two-dollar notes
    - 10 one-dollar coins
    - 25 twenty-cent coins
    - 50 ten-cent coins
    correctAns: 50 ten-cent coins
  - questionInfo: A horse has 4 legs. There are 9 horses in the barn. How many legs
      are there?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 13
    - 5
    - 36
    - 32
    correctAns: 36
  - questionInfo: Danish has 48 pencils. He needs to divide it equally into 6 boxes.
      How many pencils are there in each box?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 6
    - 7
    - 8
    - 9
    correctAns: 8
