  m_Name: 
  m_EditorClassIdentifier: 
  quizUI: {fileID: 47144273}
  questions:
  - questionInfo: 
    questionType: 1
    imageText: The clock face shows _____.
    questionImg: {fileID: 21300000, guid: 7470b756104c648acafefd3817508316, type: 3}
    options:
    - 6 o'clock
    - 10 o'clock
    - half past 9
    - half past 10
    correctAns: half past 9
  - questionInfo: 
    questionType: 1
    imageText: Which toy costs the least?
    questionImg: {fileID: 21300000, guid: d0bff49608b954e349adaec3dc48db85, type: 3}
    options:
    - ball
    - toy car
    - robot
    - teddy bear
    correctAns: ball
  - questionInfo: 
    questionType: 1
    imageText: Penny spent $40 on 2 toys. Which 2 toys are they?
    questionImg: {fileID: 21300000, guid: d0bff49608b954e349adaec3dc48db85, type: 3}
    options:
    - ball + toy car
    - toy car + robot
    - robot + teddy bear
    - teddy bear + toy car
    correctAns: robot + teddy bear
  - questionInfo: 
    questionType: 1
    imageText: Choose the correct addition equation for the picture below.
    questionImg: {fileID: 21300000, guid: 8c964a6ca65ed423e8b6f2ba874111ff, type: 3}
    options:
    - 12 + 50 = 62
    - 22 + 50 = 72
    - 50 + 20 = 70
    - 52 + 20 = 72
    correctAns: 22 + 50 = 72
  - questionInfo: Complete the  number pattern.             102, 98, 94, _____, 86
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 90
    - 92
    - 88
    - 94
    correctAns: 90
  - questionInfo: _____ tens 15 ones = 45
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 40
    - 4
    - 3
    - 30
    correctAns: 3
  - questionInfo: '48 + 16 = 5 tens _____ ones '
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 4
    - 14
    - 54
    - 64
    correctAns: 14
  - questionInfo: There are 5 groups of 3 books. How many books are there?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 15
    - 2
    - 8
    - 35
    correctAns: 15
  - questionInfo: Daisy has $10. She bought a chicken rice for $4.50 and a drink
      that costs 1.50. How much did she have left?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - $6
    - $4
    - $8.50
    - $5.50
    correctAns: $4
  - questionInfo: A bag of oranges is aplit between 4 people. Each of them receives
      3 oranges. How many oranges were there at the start?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 7
    - 12
    - 24
    - 10
    correctAns: 12
  animator: {fileID: 1784732246}
