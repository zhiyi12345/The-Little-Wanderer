MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 844788638}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: cdf0a0e20a20c4f7e8a0b2281f51dcd3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  quizUI: {fileID: 181283507}
  questions:
  - questionInfo: 
    questionType: 1
    imageText: Which clock shows the correct time?
    questionImg: {fileID: 21300000, guid: 9a1eb5a139c514842acda668c7b125d2, type: 3}
    options:
    - A
    - B
    - C
    - D
    correctAns: D
  - questionInfo: 
    questionType: 1
    imageText: Fill in the missing number?
    questionImg: {fileID: 21300000, guid: 9d285c7a41d3e42889c186756968fd5e, type: 3}
    options:
    - 59
    - 9
    - 43
    - 93
    correctAns: 93
  - questionInfo: 
    questionType: 1
    imageText: The notes and coins below are split between 5 people. How much does
      each receives?
    questionImg: {fileID: 21300000, guid: d9e586a11b15f48ad96305b6c8be5545, type: 3}
    options:
    - $41
    - $8
    - $8.10
    - $8.20
    correctAns: $8.20
  - questionInfo: 
    questionType: 1
    imageText: How many four-sided shapes are there in the picture below?
    questionImg: {fileID: 21300000, guid: f4a7007fd0ba04e2cb9687b373050e37, type: 3}
    options:
    - 4
    - 5
    - 6
    - 7
    correctAns: 6
  - questionInfo: Jill gave away 28 sweets and had 45 sweets left. How many sweets
      did she have at the start?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 17
    - 63
    - 73
    - 85
    correctAns: 73
  - questionInfo: Ms Tan has 10 apples. Mr Tan has 5 times more apple than her. How
      many apples do they have together?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 50
    - 60
    - 70
    - 80
    correctAns: 60
  - questionInfo: Owen sold 5 watermelon juice and 3 orange juice. An orange juice
      costs 50 cents and a watermelon juice costs 3 times more than an orange juice.
      How much did Owen get?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - $1.50
    - $7.50
    - $9.00
    - $11.50
    correctAns: $9.00
  - questionInfo: Which option is different from the rest?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 8 groups of 9
    - 6 tens 3 ones + 9
    - seventy-two
    - seven ones two tens
    correctAns: seven ones two tens
  - questionInfo: 
    questionType: 1
    imageText: Jill has $1 and spent all her money buying stationaries (can buy more
      than 1 each). What is the most number of stationaries she can buy?
    questionImg: {fileID: 21300000, guid: 72a7e7c9113f24ba6a00f91637a36129, type: 3}
    options:
    - 1
    - 2
    - 3
    - 4
    correctAns: 4
  - questionInfo: 'Subtract 27 from 64. '
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 91
    - 101
    - 47
    - 37
    correctAns: 37
  animator: {fileID: 892831975}
  score: 0
  totalquestions: 0
