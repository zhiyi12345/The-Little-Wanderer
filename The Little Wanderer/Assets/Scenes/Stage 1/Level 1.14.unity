  m_Name: 
  m_EditorClassIdentifier: 
  quizUI: {fileID: 69500871}
  questions:
  - questionInfo: There are 2 plates. There are 9 apples on each plate. Mandy wants
      to share the apples equally with Janice and Emily. How many apples does each
      girl get?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 18
    - 3
    - 6
    - 9
    correctAns: 6
  - questionInfo: What is 21 less than 43?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 22
    - 21
    - 25
    - 24
    correctAns: 22
  - questionInfo: Pick the smallest number.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 52
    - 34
    - 19
    - 40
    correctAns: 19
  - questionInfo: Pick the option where the first number is larger than the second
      number.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 14 and 27
    - 20 and 23
    - 7 and 12
    - 17 and 15
    correctAns: 17 and 15
  - questionInfo: 
    questionType: 1
    imageText: Which bag is 6th from the RIGHT?
    questionImg: {fileID: 21300000, guid: b8919d0b7c074411ea1401d43fe28f6d, type: 3}
    options:
    - F
    - D
    - G
    - E
    correctAns: F
  - questionInfo: 
    questionType: 1
    imageText: How many shapes are there in total?
    questionImg: {fileID: 21300000, guid: 867d762c3344c443890de8b92680682d, type: 3}
    options:
    - 18
    - 21
    - 20
    - 19
    correctAns: 19
  - questionInfo: 
    questionType: 1
    imageText: How many pentagons are there?
    questionImg: {fileID: 21300000, guid: 867d762c3344c443890de8b92680682d, type: 3}
    options:
    - 0
    - 4
    - 6
    - 2
    correctAns: 0
  - questionInfo: Mitch has 8 hair ties. Her sister gave her 5 more while her mom
      gave her another 3. How many hair ties does she have now?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 13
    - 16
    - 18
    - 11
    correctAns: 16
  - questionInfo: Look at the word "MATHEMATICS". What is the letter before E?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - H
    - M
    - T
    - C
    correctAns: H
  - questionInfo: Nick finished his dinner at 7.30pm. He spent 45 mins eating. When
      did he start eating?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 6.30pm
    - 6.45pm
    - 7.00pm
    - 7.15pm
    correctAns: 6.45pm
  animator: {fileID: 1222657691}
  score: 0
  totalquestions: 0
