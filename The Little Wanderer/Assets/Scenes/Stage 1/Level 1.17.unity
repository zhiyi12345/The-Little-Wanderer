MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2098329263}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: cdf0a0e20a20c4f7e8a0b2281f51dcd3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  quizUI: {fileID: 1606698693}
  questions:
  - questionInfo: I am a 2 digit-number. The digits in the ones place is 6. When
      you add 20 to me, I am still less than 40. What am I?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 16
    - 26
    - 36
    - 46
    correctAns: 16
  - questionInfo: Terry has 16 cars. After Belle gave Terry 2 cars, they both have
      the same number of cars. How many cars do they have in total?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 18
    - 36
    - 32
    - 34
    correctAns: 36
  - questionInfo: What is 39-16?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - twenty-two
    - forty-three
    - twenty-three
    - fifty-five
    correctAns: twenty-three
  - questionInfo: 35 = 2 tens _____ ones.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 5
    - 15
    - 33
    - 3
    correctAns: 15
  - questionInfo: Mrs Lee has some buns. She sold 15 buns and have 17 buns left.
      How many buns did she have at first?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 22
    - 32
    - 34
    - 23
    correctAns: 32
  - questionInfo: 
    questionType: 1
    imageText: Susan does her homework during the time shown below. When does she
      does her homework?
    questionImg: {fileID: 21300000, guid: 07dab1cb0e03949bdbbf687e5e8f3e59, type: 3}
    options:
    - 7 o'clock
    - half past 12
    - half past 6
    - 12 o"clock
    correctAns: 7 o'clock
  - questionInfo: 
    questionType: 1
    imageText: What is the value of the star?
    questionImg: {fileID: 21300000, guid: 98e590d5d52424481b46b534642258c0, type: 3}
    options:
    - 2
    - 6
    - 1
    - 8
    correctAns: 2
  - questionInfo: Choose the answer that equals to 67.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 64 + 13
    - 9 + 58
    - 5 + 17
    - 30 + 47
    correctAns: 9 + 58
  - questionInfo: 
    questionType: 1
    imageText: Which of the line below is the shortest?
    questionImg: {fileID: 21300000, guid: 7246fd4aff7c244b2acd4c1f171ce809, type: 3}
    options:
    - A
    - B
    - C
    - D
    correctAns: B
  - questionInfo: Jordan has 5 two-dollar notes, 3 five-dollar notes and 2 ten-dollar
      notes. He wants to buy the most expensive toy he can buy. Which toy should
      be buy?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - Teddy bear ($30.20)
    - Nitendo Switch ($54.90)
    - Barbie Doll ($45.50)
    - Football Table ($42.60)
    correctAns: Football Table ($42.60)
  animator: {fileID: 1163626104}
  score: 0
  totalquestions: 0
