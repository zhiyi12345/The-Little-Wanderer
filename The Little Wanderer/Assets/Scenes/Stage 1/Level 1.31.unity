  quizUI: {fileID: 1774756036}
  questions:
  - questionInfo: 
    questionType: 1
    imageText: There are as many _____ as _____.
    questionImg: {fileID: 21300000, guid: 014f94b98c68f499497240ce8715bdfe, type: 3}
    options:
    - Car and Doll
    - Robot and Bear
    - Bear and Car
    - Plane and Car
    correctAns: Bear and Car
  - questionInfo: 
    questionType: 1
    imageText: Which combination gives the highest number of toys?
    questionImg: {fileID: 21300000, guid: 014f94b98c68f499497240ce8715bdfe, type: 3}
    options:
    - Doll and Robot
    - Plane and Car
    - Plane and Bear
    - Doll and Car
    correctAns: Doll and Car
  - questionInfo: 
    questionType: 1
    imageText: What is the missing number?
    questionImg: {fileID: 21300000, guid: b0df337fe88d74a0982470679a6c740b, type: 3}
    options:
    - 1
    - 2
    - 0
    - 3
    correctAns: 2
  - questionInfo: Ms Tan gives 8 apples to 4 boys. How many apples did each boy receive?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 2
    - 4
    - 6
    - 8
    correctAns: 2
  - questionInfo: Which number gives a remainder when divided by 4?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 4
    - 8
    - 16
    - 11
    correctAns: 11
  - questionInfo: 5 + 5 + 5 + 5 + 5 = 5 X _____
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 5
    - 6
    - 20
    - 25
    correctAns: 5
  - questionInfo: What is the value of 9 X 4?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 5
    - 13
    - 32
    - 36
    correctAns: 36
  - questionInfo: Linda has $40 dollars. She spent $28 on a watch. How much does
      she have left?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - $12
    - $22
    - $18
    - $28
    correctAns: $12
  - questionInfo: Subtract 15 from 28.
    questionType: 0
    imageText: 
