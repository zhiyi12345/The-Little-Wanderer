  m_Script: {fileID: 11500000, guid: cdf0a0e20a20c4f7e8a0b2281f51dcd3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  quizUI: {fileID: 1316545934}
  questions:
  - questionInfo: 
    questionType: 1
    imageText: How many cars are there?
    questionImg: {fileID: 21300000, guid: b20ed4a92b1cc4fc98dfe3515b496bcb, type: 3}
    options:
    - 6 X 3
    - 2 twos
    - 6 groups of 2
    - 2 + 2 + 2 + 2 + 2
    correctAns: 6 groups of 2
  - questionInfo: 
    questionType: 1
    imageText: What is the time shown below?
    questionImg: {fileID: 21300000, guid: 4eb7206a5dd6b4383a41dcc846d90f2e, type: 3}
    options:
    - 5 o'clock
    - half past 5
    - half past 6
    - half past 7
    correctAns: half past 5
  - questionInfo: 
    questionType: 1
    imageText: What is the position of the ambulance from the right?
    questionImg: {fileID: 21300000, guid: d80f46f073b864e57b67d9d6893eaadd, type: 3}
    options:
    - 2nd
    - 3rd
    - 4th
    - 5th
    correctAns: 4th
  - questionInfo: 4 tens 1 ones + 17 = 5 tens _____ ones
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 8
    - 18
    - 16
    - 6
    correctAns: 8
  - questionInfo: There are 18 children in the park. There are 13 more adults than
      children. How many adults are in the park?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 21
    - 31
    - 18
    - 5
    correctAns: 31
  - questionInfo: There were some birds on the tree. 7 birds flew away and 32 birds
      were left. How many birds were there at the start?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 25
    - 39
    - 46
    - 38
    correctAns: 39
  - questionInfo: John was asked to buy a $65 bag. However, he only has $32 and has
      to borrow the rest from David. David had $50 initially, how much does he have
      after lending John money?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - $33
    - $18
    - $15
    - $17
    correctAns: $17
  - questionInfo: A jug of water can contain 6 cups of water. Each cup of water consist
      of 1.5ml of water. How much can the jug of water hold?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 3 litres
    - 1.5 litres
    - 6 litres
    - 9 litres
    correctAns: 
  - questionInfo: A bag of sweets contains 12 lemon-flavoured and 15 grape-flavoured
      sweets. How many people can it be shared with equally such that everyone has
      the same number of both lemon and grape-flavoured sweets.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 1
    - 3
    - 4
    - 5
    correctAns: 3
  - questionInfo: 
    questionType: 1
    imageText: Subtract.
    questionImg: {fileID: 21300000, guid: b88b7e16107aa4d8f94844d09ee77baf, type: 3}
    options:
    - 86
    - 76
    - 66
    - 56
