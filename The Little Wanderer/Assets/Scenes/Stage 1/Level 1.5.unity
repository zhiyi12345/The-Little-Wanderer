  questions:
  - questionInfo: Mr Koh bought 19 apples. Mrs Lim bought 5 fewer apples than Mr
      Koh. How many apples did Mrs Lim buy?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 24
    - 14
    - 16
    - 22
    correctAns: 14
  - questionInfo: 
    questionType: 1
    imageText: Who scored the highest marks?
    questionImg: {fileID: 21300000, guid: 319946416a9c343f7a7d93534858c393, type: 3}
    options:
    - Peter
    - Ravi
    - Amin
    - Tom
    correctAns: Peter
  - questionInfo: 
    questionType: 1
    imageText: How many more marks did Peter score than Ravi?
    questionImg: {fileID: 21300000, guid: 319946416a9c343f7a7d93534858c393, type: 3}
    options:
    - 7
    - 12
    - 3
    - 8
    correctAns: 7
  - questionInfo: Which pair add up to 14?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 3 + 10
    - 7 + 8
    - 6 + 8
    - 3 + 9
    correctAns: 6 + 8
  - questionInfo: Which statement is correct?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 5 + 6 - 2 = 7
    - 4 + 10 + 3 = 11
    - 5 - 3 + 8 = 10
    - 2 - 4 + 10 = 6
    correctAns: 5 - 3 + 8 = 10
  - questionInfo: Which shape has 6 sides?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - Triangle
    - Circle
    - Square
    - Hexagon
    correctAns: Hexagon
  - questionInfo: When u add 8 to me, the number is 17. What am I?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 8
    - 9
    - 11
    - 25
    correctAns: 9
  - questionInfo: 
    questionType: 1
    imageText: What is the value of the heart?
    questionImg: {fileID: 21300000, guid: eb1fde122e3844454a78fe472a346b49, type: 3}
    options:
    - 2
    - 4
    - 6
    - 8
    correctAns: 6
  - questionInfo: Lynn has 18 stickers. Cindy has 6 stickers. Kyra has 4 more stickers
