    correctAns: 2
  - questionInfo: 
    questionType: 1
    imageText: What does the following represent?
    questionImg: {fileID: 21300000, guid: 894b78311d48a49e7b1d78b645158454, type: 3}
    options:
    - 3 + 3 + 3
    - 4 + 4 + 4 + 4
    - 3 groups of 4
    - 4 groups of 3
    correctAns: 3 groups of 4
  - questionInfo: 
    questionType: 1
    imageText: How much would Ali have after spending $12.40 on some apples?
    questionImg: {fileID: 21300000, guid: 6527352e3bbe040678ab78ffc18f5079, type: 3}
    options:
    - $37
    - $24.60
    - $25.60
    - $34.60
    correctAns: $24.60
  - questionInfo: 
    questionType: 1
    imageText: What time does Seth has his guitar lesson?
    questionImg: {fileID: 21300000, guid: b35b7e65a53e444b69cc40c041215f78, type: 3}
    options:
    - half past 5
    - half past 4
    - 6 o'clock
    - 10 o'clock
    correctAns: half past 4
  - questionInfo: 48 - 2 tens = _____
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 28
    - 46
    - 50
    - 68
    correctAns: 28
  - questionInfo: An eraser costs 80 cents. Yasmin only has 15 cents. How much more
      does she need?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 65 cents
    - 55 cents
    - 70 cents
    - 95 cents
    correctAns: 65 cents
  - questionInfo: Susie has 20 oreos. She put 3 oreos on each cake. How many does
      she have left?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 1
    - 2
    - 3
    - 4
    correctAns: 1
  - questionInfo: 3 more than 89 is _____.
