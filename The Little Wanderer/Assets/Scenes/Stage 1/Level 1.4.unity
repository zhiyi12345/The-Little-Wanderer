  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: cdf0a0e20a20c4f7e8a0b2281f51dcd3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  quizUI: {fileID: 184672212}
  questions:
  - questionInfo: 
    questionType: 1
    imageText: What is the correct addition equation for the picture below?
    questionImg: {fileID: 21300000, guid: efda2c1b11edb44559fd99f604ab6fc0, type: 3}
    options:
    - 10 + 14 = 24
    - 10 + 15 = 25
    - 11 + 15 = 26
    - 11 + 16 = 27
    correctAns: 11 + 15 = 26
  - questionInfo: Farmer Brown collected 11 eggs on Monday and another 6 eggs on
      Tuesday. How many eggs did he collect in total?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 11 + 6 = 17
    - 11 - 6 = 5
    - 11 + 6 = 15
    - 11 - 6 = 17
    correctAns: 11 + 6 = 17
  - questionInfo: Siva has 7 stickers. Her brother gave her 3 more stickers. How
      many stickers does Siva have in total?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 10
    - 4
    - 8
    - 12
    correctAns: 10
  - questionInfo: Dan had some eggs in his bowl. 3 eggs broke. He now have 9 eggs
      left. How many eggs did Dan have at the start?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 14
    - 12
    - 9
    - 6
    correctAns: 12
  - questionInfo: 
    questionType: 1
    imageText: David is in the 3rd position. What position is John at?
    questionImg: {fileID: 21300000, guid: 8f12d9a4a6f4c477f9a7425d3d7adcd5, type: 3}
    options:
    - 6st
    - 6th
    - 6nd
    - 6rd
    correctAns: 6th
  - questionInfo: Jim had 6 stamps. His cousin had 9 stamps. How many stamps do they
      have together?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 3
    - 12
    - 16
    - 15
    correctAns: 15
  - questionInfo: There are 19 students. 7 of them are girls. How many of them are
      boys?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 26
    - 19
    - 12
    - 5
    correctAns: 12
  - questionInfo: 2, ____, 4, _____6, 7
    questionType: 0
    imageText: Complete the number pattern
    questionImg: {fileID: 0}
    options:
    - 2 and 5
    - 3 and 5
    - 2 and 4
    - 3 and 4
    correctAns: 3 and 5
  - questionInfo: There are 5 blue and red pencils. There is 1 more blue pencils
      than red pencils. How many red pencils are there?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 1
    - 2
    - 3
    - 4
    correctAns: 2
  - questionInfo: 
    questionType: 1
    imageText: How many lollipops are there?
    questionImg: {fileID: 21300000, guid: e6656885a78884c699a26df3667209f6, type: 3}
    options:
    - 13
    - 15
    - 14
    - 16
    correctAns: 
  animator: {fileID: 1969620991}
  score: 0
  totalquestions: 0
