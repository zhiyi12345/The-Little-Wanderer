  questions:
  - questionInfo: 
    questionType: 1
    imageText: What time is it now?
    questionImg: {fileID: 21300000, guid: 8039c2597f0d44175bf1ee7e1bd7a504, type: 3}
    options:
    - 12 o'clock
    - 3 o'clock
    - 6 o'clock
    - 9 o'clock
    correctAns: 12 o'clock
  - questionInfo: 
    questionType: 1
    imageText: What is the value of A and B?
    questionImg: {fileID: 21300000, guid: c368f26c8a36e4d10aaf34626053230c, type: 3}
    options:
    - A = 5, B = 3
    - A = 5, B = 4
    - A = 8, B = 3
    - A = 8, B = 4
    correctAns: A = 5, B = 3
  - questionInfo: 
    questionType: 1
    imageText: Jake only has 2 five-dollar notes. Which one of the following toys
      can he buy?
    questionImg: {fileID: 21300000, guid: 0f1ad3a8623db418583b3b29385384ce, type: 3}
    options:
    - Toy Plane
    - Toy Robot
    - Toy Car
    - Ball
    correctAns: Toy Car
  - questionInfo: 
    questionType: 1
    imageText: Mrs Lee bought 2 toys for her son. She spent a total of $35. Which
      two toys did she buy?
    questionImg: {fileID: 21300000, guid: 0f1ad3a8623db418583b3b29385384ce, type: 3}
    options:
    - Plane and Robot
    - Robot and Ball
    - Car and Ball
    - Robot and Car
    correctAns: Robot and Ball
  - questionInfo: How much is five groups of 7?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 35
    - 42
    - 12
    - 25
    correctAns: 35
  - questionInfo: Sarah has 25 cookies. She gave 8 to her sister. How many cookies
      does she have left?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 33
    - 17
    - 42
    - 21
    correctAns: 17
  - questionInfo: 3 X 9 = 1 tens _____ ones
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 27
    - 17
    - 7
    - 37
    correctAns: 17
  - questionInfo: Sam has $5. He wants to buy a bag that costs $23. How much more
      money does he need?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - $15
    - $18
    - $28
    - $20
    correctAns: $18
  - questionInfo: 'Subtract 48 from 100. '
    questionType: 0
    imageText: 
