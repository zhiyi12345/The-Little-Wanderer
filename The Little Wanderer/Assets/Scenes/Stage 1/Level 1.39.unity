  questions:
  - questionInfo: 
    questionType: 1
    imageText: The picture below shows _____
    questionImg: {fileID: 21300000, guid: 650f3556d8c0b42af8bec577d6e73b05, type: 3}
    options:
    - 2 groups of 3
    - 2 groups of 2
    - 4 groups of 2
    - 4 groups of 4
    correctAns: 4 groups of 2
  - questionInfo: 
    questionType: 1
    imageText: What time is it 20 hours later?
    questionImg: {fileID: 21300000, guid: 50e2bdde276174b8989d36e9a9ecddbd, type: 3}
    options:
    - half past 4
    - half past 3
    - half past 2
    - half past 1
    correctAns: half past 4
  - questionInfo: 
    questionType: 1
    imageText: Gerald has this amount. His brother has twice as much as him. How
      much do they have in total?
    questionImg: {fileID: 21300000, guid: 52d2795f1049144deac81d6a08ec936d, type: 3}
    options:
    - $0.85
    - $1.70
    - $2.55
    - $3.00
    correctAns: $2.55
  - questionInfo: 
    questionType: 1
    imageText: If Paul has $100, what should he buy so that he will receive the largest
      change?
    questionImg: {fileID: 21300000, guid: 9d73e7e85424741ad87996c87c6c9a35, type: 3}
    options:
    - Kettle and Oven
    - Oven and Pot
    - Kettle and Pot
    - 2 Kettles
    correctAns: Kettle and Pot
  - questionInfo: There are 48 students in the class. There are 3 times more boys
      than girls. How many girls are there?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 48
    - 36
    - 24
    - 12
    correctAns: 12
  - questionInfo: There are 9 boxes. Each boxes has 8 mangos. How many mangos are
      there in total?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 17
    - 24
    - 72
    - 49
    correctAns: 72
  - questionInfo: Subtract 83 - 35.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 57
    - 58
    - 47
    - 48
    correctAns: 48
  - questionInfo: 9 + 86 = _____
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 8 tens 6 ones
    - 8 tens 9 ones
    - 9 tens 0 ones
    - 9 tens 5 ones
    correctAns: 9 tens 5 ones
  - questionInfo: What is 63 divided by 7?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 10
    - 9
    - 11
    - 8
    correctAns: 9
  - questionInfo: Mrs Tan has 50 big and small magnets. She has 15 big magnets. How
      many small magnets does she have?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 35
    - 45
    - 65
    - 75
    correctAns: 35
