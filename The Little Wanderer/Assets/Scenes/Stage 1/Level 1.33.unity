  quizUI: {fileID: 610075809}
  questions:
  - questionInfo: There are 10 bunches of bananas. Each bunch has 3 bananas. How
      many bananas are there altogether?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 13
    - 7
    - 30
    - 20
    correctAns: 30
  - questionInfo: 
    questionType: 1
    imageText: What is the missing number?
    questionImg: {fileID: 21300000, guid: d9e7ec407142d42eb9fa03f457851332, type: 3}
    options:
    - 3
    - 4
    - 5
    - 6
    correctAns: 4
  - questionInfo: 
    questionType: 1
    imageText: Which is the correct equation to count the number of flowers present?
    questionImg: {fileID: 21300000, guid: e4b4b1fb7e7614dfa8f4505f7e80197f, type: 3}
    options:
    - 5 X 3 = 15
    - 5 + 5 + 5 + 5 + 5 = 25
    - 3 + 3 + 3 = 9
    - 3 X 4 = 12
    correctAns: 5 X 3 = 15
  - questionInfo: 
    questionType: 1
    imageText: Peter bought one of the items below. He had 50 cents. How much change
      did he get?
    questionImg: {fileID: 21300000, guid: bb71924c873684ea0aea45ba12a60d15, type: 3}
    options:
    - 10 cents
    - 20 cents
    - 30 cents
    - 40 cents
    correctAns: 10 cents
  - questionInfo: A ruler costs 20 cents and an eraser costs 30 cents. Rachel bought
      2 rulers and 1 eraser. How much did she spent?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 30 cents
    - 40 cents
    - 90 cents
    - 70 cents
    correctAns: 70 cents
  - questionInfo: Which one of the options is not the same as the others?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - eighty-six
    - 86
    - 8 tens 6 ones
    - 6 tens 8 ones
    correctAns: 6 tens 8 ones
  - questionInfo: What is 70 smaller than?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 82
    - 54
    - 47
    - 69
    correctAns: 82
  - questionInfo: Complete the pattern.                           58, 48, 38, _____,
      18
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 28
    - 8
    - 34
    - 26
    correctAns: 28
  - questionInfo: Subtract 51 - 28.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 23
    - 33
    - 13
    - 43
    correctAns: 23
  - questionInfo: What can I exchange a two-dollar note with?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 4 one-dollar coins
    - 5 fifty-cents coins
    - 10 twenty-cents coins
    - 25 ten-cents coins
    correctAns: 10 twenty-cents coins
