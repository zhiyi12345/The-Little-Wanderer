  quizUI: {fileID: 2048691869}
  questions:
  - questionInfo: 
    questionType: 1
    imageText: Cindy has 4 5 dollar notes as shown below. How much money does she
      have?
    questionImg: {fileID: 21300000, guid: 7bd664a5abac9475c8792df4ba5ac4b8, type: 3}
    options:
    - $4
    - $20
    - $16
    - $25
    correctAns: $20
  - questionInfo: 
    questionType: 1
    imageText: Dawn has this amount of coins. She wants to buy a apple that costs
      50 cents. How much does she have left?
    questionImg: {fileID: 21300000, guid: a080bc28d04034af6a012f49dddffc66, type: 3}
    options:
    - $1.30
    - $0.50
    - $0.80
    - $0.30
    correctAns: $0.80
  - questionInfo: 4 + 4 + 4 + 4 + 4 + 4 = _____ X 4
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 4
    - 5
    - 6
    - 7
    correctAns: 6
  - questionInfo: Which of the following pairs does not add up to 24?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 12 + 12
    - 10 + 14
    - 13 + 9
    - 7 + 17
    correctAns: 13 + 9
  - questionInfo: 
    questionType: 1
    imageText: Find the missing number in the heart.
    questionImg: {fileID: 21300000, guid: 08a7d8d915d004b66956c271adbecfdc, type: 3}
    options:
    - 12
    - 4
    - 14
    - 20
    correctAns: 12
  - questionInfo: 'Look at the word CARNIVAL. What is the letter before the 2nd "A". '
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - C
    - R
    - V
    - L
    correctAns: V
  - questionInfo: 15 is 7 less than _____.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 8
    - 22
    - 28
    - 23
    correctAns: 22
  - questionInfo: Look at the number pattern and fill in the missing numbers.          
      10, _____, 14, 16, _____, 20.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 12 ; 18
    - 12 ; 8
    - 11 ; 17
    - 12 ; 15
    correctAns: 12 ; 18
  - questionInfo: 
    questionType: 1
    imageText: How many keys are there below?
    questionImg: {fileID: 21300000, guid: 381d570e5236a4b1594b985cd1bcea8c, type: 3}
    options:
    - sixteen
    - seventeen
    - eighteen
    - nineteen
    correctAns: seventeen
  - questionInfo: Select the 2 pairs that give the same answer.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 17 + 2 and 20 - 5
    - 20 - 8 and 9 + 6
    - 10 + 4 and 18 - 3
    - 7 + 8 and 19 - 4
    correctAns: 7 + 8 and 19 - 4
