  quizUI: {fileID: 430233784}
  questions:
  - questionInfo: 30 and 9 make _____.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 39
    - 12
    - 21
    - 40
    correctAns: 39
  - questionInfo: 
    questionType: 1
    imageText: Answer the question below.
    questionImg: {fileID: 21300000, guid: 632a74b6ddc80401782b5d9589fcad4c, type: 3}
    options:
    - 4
    - 8
    - 16
    - 2
    correctAns: 8
  - questionInfo: 
    questionType: 1
    imageText: The picture below shows how much Pris has. She spent 30 cents on a
      fishball. How much does she have left?
    questionImg: {fileID: 21300000, guid: 042b00e6317e149d99b4df16d6b0f152, type: 3}
    options:
    - 80 cents
    - 60 cents
    - 40 cents
    - 50 cents
    correctAns: 50 cents
  - questionInfo: There are 7 baskets. Each basket consist of 5 flowers. How many
      flowers are there in total?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 2
    - 12
    - 35
    - 28
    correctAns: 35
  - questionInfo: James has 32 peaches. He wants to split the peaches equally with
      3 other friends. How many peaches does each of them get?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 28
    - 24
    - 8
    - 10
    correctAns: 8
  - questionInfo: 
    questionType: 1
    imageText: Isabel has to go ballet at the time shown below? The time now is 2
      o'clock. How long is it until Isabel has to go for her ballet?
    questionImg: {fileID: 21300000, guid: 6b38666eb69c04aab9a01355cff79acd, type: 3}
    options:
    - 4h 30 mins
    - 3h 30 mins
    - 5h 30 mins
    - 2h 30mins
    correctAns: 4h 30 mins
  - questionInfo: Mr Tan sold 9 bottles of banana milk and 4 bottles of chocolate
      milk. A bottle of banana milk costs $2 and a bottle of chocolate milk costs
      $1.50. How much did Mr Tan earn in total?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - $18
    - $6
    - $24
    - $21.50
    correctAns: $24
  - questionInfo: 13 + 18 = _____.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 11
    - 21
    - 31
    - 41
    correctAns: 31
  - questionInfo: Choose the option that is different from the rest.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 13 + 24
    - thirty - seven
    - 2 tens 17 ones
    - 30 - 7
    correctAns: 30 - 7
  - questionInfo: 3 girls had their height taken. Alice is taller than Carol but
      shorter than Beth. Arrange the girls in order from shortest to tallest.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - Carol, Alice, Beth
    - Alice, Beth, Carol
    - Beth, Alice, Carol
    - Carol, Beth, Alice
    correctAns: Carol, Alice, Beth
