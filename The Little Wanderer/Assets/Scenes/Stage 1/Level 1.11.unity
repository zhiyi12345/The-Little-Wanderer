  questions:
  - questionInfo: 7 tens 4 ones is 15 more than _____.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 59
    - 69
    - 61
    - 89
    correctAns: 59
  - questionInfo: 'Complete the number pattern.       98, 95, 92, _____, 86, 83 '
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 91
    - 88
    - 89
    - 87
    correctAns: 89
  - questionInfo: 
    questionType: 1
    imageText: There are how many more circles than squares?
    questionImg: {fileID: 21300000, guid: 7cfa8b31baa9d4a1b8d76577afe5cd80, type: 3}
    options:
    - 6
    - 5
    - 8
    - 3
    correctAns: 5
  - questionInfo: 
    questionType: 1
    imageText: There are how many fewer rectangles than triangles?
    questionImg: {fileID: 21300000, guid: 7cfa8b31baa9d4a1b8d76577afe5cd80, type: 3}
    options:
    - 6
    - 1
    - 5
    - 7
    correctAns: 5
  - questionInfo: Eddy has 24 game cards. He has 8 fewer game cards than Fred. How
      many game card does Fred have?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 24
    - 32
    - 16
    - 40
    correctAns: 32
  - questionInfo: Mrs Wong has 34 stamps. She has 15 stamps left after giving 15
      to Mrs Lee. How many stamps did Mrs Wong give Mrs Lee?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 49
    - 29
    - 19
    - 25
    correctAns: 19
  - questionInfo: 
    questionType: 1
    imageText: Below is Sam's timetable. What time is his swimming lesson?
    questionImg: {fileID: 21300000, guid: 52e648284911a4337916f3ce50fd1b32, type: 3}
    options:
    - half past 8
    - half past 10
    - 1 o'clock
    - 5 o'clock
    correctAns: half past 10
  - questionInfo: 'There are 17 leaves on a plant. The caterpiillars ate up 8 of
      them. Which of the following statements show how many leaves are left? '
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 17 - 8 = 9
    - 17 + 8 = 25
    - 17 - 8 = 11
    - 17 + 8 = 9
    correctAns: 17 - 8 = 9
  - questionInfo: Ahmad has 4 bags of blue marbles and 3 bags of red marbles. Each
      bag has 5 marbles. How many red marbles does Ahmad have?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 20
    - 15
    - 35
    - 25
    correctAns: 15
  - questionInfo: Mrs Eng bakes 4 cakes to sell. She adds 7 flowers on each cake.
      How many flowers did she use?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 4
    - 28
    - 16
    - 10
    correctAns: 28
