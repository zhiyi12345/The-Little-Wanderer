  quizUI: {fileID: 2074783961}
  questions:
  - questionInfo: Bob bought a bag. He gave the cashier $100 and got a $25 change.
      Hoe much was the bag?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - $75
    - $85
    - $65
    - $70
    correctAns: $75
  - questionInfo: 
    questionType: 1
    imageText: Which is the correct equation?
    questionImg: {fileID: 21300000, guid: 3412a119e314441edb5ac2e2775934df, type: 3}
    options:
    - 2 + 2 + 2 + 2 = 8
    - 2 X 2 X 2 X 2 = 16
    - 4 X 4 = 16
    - 4 + 4 + 4 = 12
    correctAns: 2 + 2 + 2 + 2 = 8
  - questionInfo: 
    questionType: 1
    imageText: Sam has _____ more yellow jelly beans than red jelly beans.
    questionImg: {fileID: 21300000, guid: 4d89e3fc204df478eafbc3387ffefd41, type: 3}
    options:
    - 7
    - 4
    - 3
    - 5
    correctAns: 3
  - questionInfo: 
    questionType: 1
    imageText: Which combination has the most amount of jellybeans?
    questionImg: {fileID: 21300000, guid: 4d89e3fc204df478eafbc3387ffefd41, type: 3}
    options:
    - Red and Orange
    - Green and Purple
    - Orange and Yellow
    - Yellow and Red
    correctAns: Orange and Yellow
  - questionInfo: 1 tens 9 ones + 16 = 1 tens _____ ones
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 35
    - 25
    - 15
    - 5
    correctAns: 25
  - questionInfo: Each kitten has 4 legs. There are 3 kittens. How many legs are
      there in together?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 4
    - 12
    - 18
