  questions:
  - questionInfo: 
    questionType: 1
    imageText: Ken has the following amount in his pocket. How much money does he
      have?
    questionImg: {fileID: 21300000, guid: 6c49d97d4433a44e1a4e5f5cd1780bce, type: 3}
    options:
    - 60 cents
    - 55 cents
    - 50 cents
    - 45 cents
    correctAns: 50 cents
  - questionInfo: 
    questionType: 1
    imageText: How many dinosaurs are there?
    questionImg: {fileID: 21300000, guid: 5790f87d9468a4c73b5bbfc7a283537d, type: 3}
    options:
    - 35
    - 25
    - 24
    - 27
    correctAns: 25
  - questionInfo: 
    questionType: 1
    imageText: Jane has this amount. She bought a toy and had $5 left. How much was
      the toy?
    questionImg: {fileID: 21300000, guid: a3fac30a68b3d4958b98cfe60cd21813, type: 3}
    options:
    - $28
    - $23
    - $33
    - $16
    correctAns: $23
  - questionInfo: 2 tens 5 ones + 9 = _____ tens + 4.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 2
    - 3
    - 30
    - 34
    correctAns: 3
  - questionInfo: 27 + _____ = 36
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 9
    - 19
    - 4
    - 3
    correctAns: 9
  - questionInfo: Mr Li gives 35 lollipops to 7 students equally. How many lollipops
      did each student receive?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 28
    - 18
    - 5
    - 4
    correctAns: 5
  - questionInfo: Ismail wants to buy 6 packets of cookies. Each packet has 8 cookies.
      How many cookies did he buy in total?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 14
    - 48
    - 40
    - 35
    correctAns: 48
  - questionInfo: 8 tens 4 ones = _____.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 80
    - 6 tens 14 ones
    - eighty-fourth
    - 7 tens 14 ones
    correctAns: 7 tens 14 ones
  - questionInfo: Add 15 + 33
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 18
    - 38
    - 45
    - 48
    correctAns: 48
  - questionInfo: Spell the number 49.
