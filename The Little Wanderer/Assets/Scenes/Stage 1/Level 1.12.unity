  questions:
  - questionInfo: Ravi has 20 marbles. He lost 2 of them. How many marbles does he
      have left?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 18
    - 20
    - 22
    - 16
    correctAns: 18
  - questionInfo: Tristan has 24 strawberries. He split in equally into 4 groups.
      How many strawberries are there in each group?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 6
    - 5
    - 4
    - 8
    correctAns: 6
  - questionInfo: 'Complete the number pattern.     21, 24, 27, _____, 33 '
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 29
    - 31
    - 32
    - 30
    correctAns: 30
  - questionInfo: 
    questionType: 1
    imageText: What is the time shown below?
    questionImg: {fileID: 21300000, guid: fede360d1f3d441beb2ad91bdea8b97a, type: 3}
    options:
    - half past 12
    - 6 o'clock
    - half past 6
    - five past 12
    correctAns: half past 12
  - questionInfo: _____ is 3 less than 18.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 15
    - 21
    - 16
    - 24
    correctAns: 15
  - questionInfo: 23 + _____ = 32
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - ' 9'
    - 11
    - 12
    - 7
    correctAns: ' 9'
  - questionInfo: Mili has 15 cents in her wallet. How much more money does she need
      to buy a pencil that costs 60 cents?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 45 cents
    - 55 cents
    - 65 cents
    - 75 cents
    correctAns: 45 cents
  - questionInfo: 
