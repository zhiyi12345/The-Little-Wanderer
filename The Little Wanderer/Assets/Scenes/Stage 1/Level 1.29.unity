MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2121193728}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: cdf0a0e20a20c4f7e8a0b2281f51dcd3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  quizUI: {fileID: 402434634}
  questions:
  - questionInfo: 
    questionType: 1
    imageText: What is the missing number?
    questionImg: {fileID: 21300000, guid: 3292c3ba8523040e4b1e9f9fcb9cdcb4, type: 3}
    options:
    - 4
    - 5
    - 6
    - 7
    correctAns: 6
  - questionInfo: 
    questionType: 1
    imageText: A student has this much money left after spending $1.60 on a pencil
      and $0.60 on a eraser. How much did he have at first?
    questionImg: {fileID: 21300000, guid: 004ba786a58494c00bd6f9902b9ea364, type: 3}
    options:
    - $5
    - $2.20
    - $7.20
    - $2.80
    correctAns: $7.20
  - questionInfo: At a fruit stall. There are 65 apples. There are 25 fewer watermelons
      than apples. How many watermelons were there?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 80
    - 40
    - 90
    - 50
    correctAns: 40
  - questionInfo: Joan has 30 books. Jane has 12 books. How many books must Joan
      lend to Jane such that both of them have an equal number of books?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 42
    - 21
    - 18
    - 9
    correctAns: 9
  - questionInfo: A farmer has 39 apples. He is trying to divide it into 5 baskets.
      How many extra apples are there?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 35
    - 7
    - 4
    - 3
    correctAns: 4
  - questionInfo: 
    questionType: 1
    imageText: Look at the picture. How many balls are there in total?
    questionImg: {fileID: 21300000, guid: 20aeca3202771400a87cdc2d8949865b, type: 3}
    options:
    - 5 X 3
    - 8 + 8 + 8
    - 8 groups of 3
    - 8 eights
    correctAns: 8 + 8 + 8
  - questionInfo: There are 14 marbles. It is divided into 2 groups. How many marbles
      does each group have?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 7
    - 14
    - 4
    - 8
    correctAns: 7
  - questionInfo: A school dorm has 4 levels. Each level has 12 rooms. How many rooms
      does the school dorm have?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 16
    - 24
    - 48
    - 30
    correctAns: 48
  - questionInfo: The time now is 1 o'clock. What would the time be 14 hours from
      now?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 3 o'clock
    - 12 o'clock
    - 1 o'clock
    - 2 o'clock
    correctAns: 3 o'clock
  - questionInfo: 4 tens 9 ones = 2 tens _____ ones
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 39
    - 29
    - 19
    - 9
    correctAns: 29
  animator: {fileID: 217116973}
  score: 0
  totalquestions: 0
