  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 161213739}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: cdf0a0e20a20c4f7e8a0b2281f51dcd3, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  quizUI: {fileID: 535728763}
  questions:
  - questionInfo: 
    questionType: 1
    imageText: Jane paid $50 for the most expensive toy shown below. How much change
      did she receive?
    questionImg: {fileID: 21300000, guid: d69e748111bdd4b0996f98d9e8d0f385, type: 3}
    options:
    - $15
    - $27
    - $33
    - $25
    correctAns: $15
  - questionInfo: Teddy has a total of 83 pink and blue balloons. There are 45 pink
      balloons. How many blue balloons are there?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 48
    - 38
    - 29
    - 32
    correctAns: 38
  - questionInfo: 
    questionType: 1
    imageText: The picture below shows _____ apples.
    questionImg: {fileID: 21300000, guid: 30fb549af343c412b818f4f638ccf5be, type: 3}
    options:
    - 5 groups of 10
    - 2 groups of 10
    - 10 groups of 2
    - 4 groups of 5
    correctAns: 4 groups of 5
  - questionInfo: A one-dollar coin can be exchanged for _____ coins.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 10 five-cent
    - 2 ten-cent
    - 3 fifty-cent
    - 5 twenty-cent
    correctAns: 5 twenty-cent
  - questionInfo: 4 threes = _____.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 4 + 4 + 4
    - 4 X 4 X 4
    - 3 + 3 + 3 + 3
    - 3 X 3 X 3 X 3
    correctAns: 3 + 3 + 3 + 3
  - questionInfo: 
    questionType: 1
    imageText: Joshua has this amount in this wallet. How much does he have?
    questionImg: {fileID: 21300000, guid: a616f87c3b3064a64801073ca98faf08, type: 3}
    options:
    - $27
    - $30
    - $20
    - $22
    correctAns: $30
  - questionInfo: Jay has 15 balls. Paul has 11 balls. How many balls does Jay need
      to give Paul so that they ahve an equal number of balls.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 4
    - 2
    - 13
    - 5
    correctAns: 2
  - questionInfo: Kathy went to the market to buy 5 packets of fishball. Each packet
      has 8 fishballs. How many fishballs are there in total?
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 40
    - 13
    - 32
    - 48
    correctAns: 40
  - questionInfo: 
    questionType: 1
    imageText: Ryan spent $18 at the restaurant. What did he buy?
    questionImg: {fileID: 21300000, guid: 4e8301d9e80644c08accf4ee71dfc5a4, type: 3}
    options:
    - Spaghetti and Pizza
    - Pizza and Chicken
    - Spaghetti and Chicken
    - 2 Pizzas
    correctAns: Spaghetti and Chicken
  - questionInfo: Pauline has piano lesson at 6 o'clock. It is half past 12 now.
      How many hours does Pauline has until her piano lesson.
    questionType: 0
    imageText: 
    questionImg: {fileID: 0}
    options:
    - 6 hours
    - 5 hours 30 minutes
    - 6 hours 30 minutes
    - 4 hours 30 minutes
    correctAns: 5 hours 30 minutes
  animator: {fileID: 315168351}
  score: 0
  totalquestions: 0
